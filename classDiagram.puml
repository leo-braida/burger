@startuml
skinparam style strictuml
skinparam classAttributeIconSize 0

' ==========================================
' CREATIONAL PATTERNS (5)
' ==========================================

' --- Singleton ---
class MenuManager <<Singleton>> {
    - static instance: MenuManager
    - MenuManager()
    + static getInstance(): MenuManager
    + getMenu(): List<OrderComponent>
}

' --- Prototype & Composite ---
abstract class OrderComponent <<Prototype>> <<Composite Component>> {
    # name: String
    # price: double
    + getName(): String
    + getPrice(): double
    + abstract clone(): OrderComponent
    + abstract accept(visitor: OrderVisitor)
}

class OrderItem <<Composite Leaf>> extends OrderComponent  {
    + clone(): OrderComponent
    + accept(visitor: OrderVisitor)
}

class Combo <<Composite>> extends OrderComponent  {
    - items: List<OrderComponent>
    + addItem(item: OrderComponent)
    + getPrice(): double
    + clone(): OrderComponent
    + accept(visitor: OrderVisitor)
}

class Drink extends OrderItem {}
class Extra extends OrderItem {}
abstract class Burger extends OrderItem {}

' --- Builder ---
class BurgerBuilder <<Builder>> {
    - burger: Burger
    + reset()
    + addMeat(): BurgerBuilder
    + addCheese(): BurgerBuilder
    + addLettuce(): BurgerBuilder
    + getResult(): Burger
}

' --- Factory Method ---
class BurgerFactory <<Factory Method>> {
    + createBurger(type: String): Burger
}
class StandardBurger extends Burger {}
class Cheeseburger extends Burger {}
class Baconburger extends Burger {}
BurgerFactory ..> Burger : creates

' --- Abstract Factory ---
interface ComboAbstractFactory <<Abstract Factory>> {
    + createBurger(): Burger
    + createDrink(): Drink
    + createExtra(): Extra
}
class DoubleBaconFactory implements ComboAbstractFactory {
    + createBurger(): Burger
    + createDrink(): Drink
    + createExtra(): Extra
}
class CheeseLoveFactory implements ComboAbstractFactory {
    + createBurger(): Burger
    + createDrink(): Drink
    + createExtra(): Extra
}

' ==========================================
' STRUCTURAL PATTERNS (7)
' ==========================================

' --- Bridge ---
interface OrderOriginPlatform <<Bridge Implementor>> {
    + processOriginDetails(): String
}
class WhatsappPlatform implements OrderOriginPlatform {
    + processOriginDetails(): String
}
class AppPlatform implements OrderOriginPlatform {
    + processOriginDetails(): String
}

' --- Decorator ---
abstract class OrderDecorator <<Decorator>> extends OrderComponent  {
    # wrappedItem: OrderComponent
    + OrderDecorator(item: OrderComponent)
    + getPrice(): double
    + clone(): OrderComponent
    + accept(visitor: OrderVisitor)
}
class DeliveryFeeDecorator extends OrderDecorator {
    - deliveryFee: double
    + getPrice(): double
}
class TipDecorator extends OrderDecorator {
    - tipAmount: double
    + getPrice(): double
}

' --- Flyweight ---
interface IngredientFlyweight <<Flyweight>> {
    + getName(): String
    + getCalories(): int
}
class SharedIngredient implements IngredientFlyweight {
    - name: String
    - calories: int
    + getName(): String
    + getCalories(): int
}
class IngredientFactory {
    - ingredientsMap: Map<String, IngredientFlyweight>
    + getIngredient(name: String): IngredientFlyweight
}
IngredientFactory o-> IngredientFlyweight

' --- Facade ---
class DeliverySystemFacade <<Facade>> {
    - dispatcher: CentralDispatcher
    - menuManager: MenuManager
    + placeOrder(order: Order, payment: PaymentStrategy)
    + trackOrder(orderId: String): String
}

' --- Proxy ---
interface MenuCacheProxy <<Proxy>> {
    + getAvailableItems(): List<String>
}
class RealMenu implements MenuCacheProxy {
    + getAvailableItems(): List<String>
}
class CachedMenuProxy implements MenuCacheProxy {
    - realMenu: RealMenu
    - cache: List<String>
    + getAvailableItems(): List<String>
}
CachedMenuProxy -> RealMenu

' --- Adapter ---
interface DeliveryAPI <<Adapter Target>> {
    + sendOrderToPartner(orderDetails: String)
}
class IFoodAdapter <<Adapter>> implements DeliveryAPI  {
    - ifoodService: Object
    + sendOrderToPartner(orderDetails: String)
}
class RappiAdapter <<Adapter>> implements DeliveryAPI  {
    - rappiService: Object
    + sendOrderToPartner(orderDetails: String)
}

' ==========================================
' BEHAVIORAL PATTERNS (11)
' ==========================================

' --- State ---
interface OrderState <<State>> {
    + nextState(order: Order)
    + cancelOrder(order: Order)
}
class NewState <<Singleton>> implements OrderState {
+ nextState(order: Order) 
+ cancelOrder(order: Order) 
}
class PreparingState <<Singleton>> implements OrderState { 
+ nextState(order: Order)  + cancelOrder(order: Order) }
class ReadyState <<Singleton>> implements OrderState { + nextState(order: Order) \n + cancelOrder(order: Order) }
class DeliveringState <<Singleton>> implements OrderState { + nextState(order: Order) \n + cancelOrder(order: Order) }
class DeliveredState <<Singleton>> implements OrderState { + nextState(order: Order) \n + cancelOrder(order: Order) }
class CancelledState <<Singleton>> implements OrderState { + nextState(order: Order) \n + cancelOrder(order: Order) }

' --- Strategy ---
interface PaymentStrategy <<Strategy>> {
    + pay(amount: double): boolean
}
class PixPayment implements PaymentStrategy {
+ pay(amount: double): boolean
}
class CreditCardPayment implements PaymentStrategy {
+ pay(amount: double): boolean
}
class CashPayment implements PaymentStrategy {
+ pay(amount: double): boolean
}

' --- Observer ---
interface OrderObserver <<Observer>> {
    + update(order: Order)
}
class ClientApp implements OrderObserver {
+ update(order: Order)
}
class CourierApp implements OrderObserver {
+ update(order: Order)
}

' --- Iterator ---
interface OrderIterator <<Iterator>> {
    + hasNext(): boolean
    + next(): OrderComponent
}
class OrderItemIterator implements OrderIterator {
    - items: List<OrderComponent>
    - position: int
    + hasNext(): boolean
    + next(): OrderComponent
}

' --- Main Context: Order (Bridge Abstraction, Iterable, Context) ---
class Order <<Bridge Abstraction>> {
    - id: String
    - state: OrderState
    - paymentMethod: PaymentStrategy
    - originPlatform: OrderOriginPlatform
    - items: List<OrderComponent>
    - observers: List<OrderObserver>
    + addObserver(o: OrderObserver)
    + notifyObservers()
    + setState(state: OrderState)
    + processPayment()
    + createIterator(): OrderIterator
    + calculateTotal(): double
    + createMemento(): OrderMemento
    + restore(m: OrderMemento)
}
Order o-> OrderState
Order o-> PaymentStrategy
Order o-> OrderOriginPlatform
Order o-> OrderObserver
Order ..> OrderItemIterator : creates

' --- Mediator ---
interface LogisticsMediator <<Mediator>> {
    + notify(sender: Object, event: String)
}
class CentralDispatcher <<Singleton>> implements LogisticsMediator  {
    - courierApp: CourierApp
    - kitchenSystem: Object
    + notify(sender: Object, event: String)
}
Order ..> CentralDispatcher : communicates

' --- Command ---
interface Command <<Command>> {
    + execute()
    + undo()
}
class AddItemCommand implements Command {
    - order: Order
    - item: OrderComponent
    + execute()
    + undo()
}
class CancelOrderCommand implements Command {
    - order: Order
    + execute()
    + undo()
}
class CashierInvoker {
    - commandHistory: List<Command>
    + executeCommand(c: Command)
}
CashierInvoker o-> Command

' --- Chain of Responsibility ---
abstract class OrderValidationHandler <<Chain of Responsibility>> {
    # next: OrderValidationHandler
    + setNext(handler: OrderValidationHandler): OrderValidationHandler
    + handle(order: Order): boolean
}
class DeliveryAreaHandler extends OrderValidationHandler {
+ handle(order: Order): boolean
}
class PaymentHandler extends OrderValidationHandler {
+ handle(order: Order): boolean
}
class StockHandler extends OrderValidationHandler {
+ handle(order: Order): boolean
}

' --- Template Method ---
abstract class ItemPreparer <<Template Method>> {
    + process()
    # abstract prepareIngredients()
    # abstract cook()
    # packageItem()
}
class BurgerPreparer extends ItemPreparer {
    # prepareIngredients()
    # cook()
}
class DrinkPreparer extends ItemPreparer {
    # prepareIngredients()
    # cook()
}

' --- Memento ---
class OrderMemento <<Memento>> {
    - stateData: String
    - itemsSnapshot: List<OrderComponent>
    + getStateData(): String
    + getItemsSnapshot(): List<OrderComponent>
}
class OrderHistoryCaretaker {
    - history: List<OrderMemento>
    + save(order: Order)
    + undo(order: Order)
}
OrderHistoryCaretaker o-> OrderMemento

' --- Interpreter ---
interface SearchExpression <<Interpreter>> {
    + interpret(context: Order): boolean
}
class StatusExpression implements SearchExpression {
    - requiredState: Class
    + interpret(context: Order): boolean
}
class ValueExpression implements SearchExpression {
    - minValue: double
    + interpret(context: Order): boolean
}
class AndExpression implements SearchExpression {
    - expr1: SearchExpression
    - expr2: SearchExpression
    + interpret(context: Order): boolean
}
AndExpression o-> SearchExpression

' --- Visitor ---
interface OrderVisitor <<Visitor>> {
    + visitItem(item: OrderItem)
    + visitCombo(combo: Combo)
    + visitDecorator(decorator: OrderDecorator)
}
class KitchenVisitor implements OrderVisitor {
    + visitItem(item: OrderItem)
    + visitCombo(combo: Combo)
    + visitDecorator(decorator: OrderDecorator)
}
class PricingVisitor implements OrderVisitor {
    + visitItem(item: OrderItem)
    + visitCombo(combo: Combo)
    + visitDecorator(decorator: OrderDecorator)
}
class PackagingVisitor implements OrderVisitor {
    + visitItem(item: OrderItem)
    + visitCombo(combo: Combo)
    + visitDecorator(decorator: OrderDecorator)
}
@enduml